# MySQL Server Configuration File (auto-generated by Ansible)
# Generated from template: my.cnf.j2

[mysqld]
# MySQL Port and Socket
port={{ mysql_port }}
socket={{ mysql_socket }}
bind-address={{ mysql_bind_address }}

# Data and Log Directories
datadir={{ mysql_data_dir }}
log-error={{ mysql_log_dir }}/error.log
pid-file=/var/run/mysqld/mysqld.pid

# Character Set
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

# Connection Settings
max_connections={{ mysql_max_connections }}
max_allowed_packet={{ mysql_max_allowed_packet }}
thread_stack=256K
thread_cache_size=8

# Storage Engine
default-storage-engine={{ mysql_default_storage_engine }}

# InnoDB Settings (MySQL 8 compatible)
innodb_buffer_pool_size={{ mysql_innodb_buffer_pool_size }}
innodb_redo_log_capacity={{ mysql_innodb_redo_log_capacity }}
innodb_file_per_table=ON
innodb_flush_log_at_trx_commit=1

# Query Logging (moved to data directory for permission compatibility)
slow_query_log={{ mysql_slow_query_log }}
slow_query_log_file={{ mysql_data_dir }}/slow_query.log
long_query_time={{ mysql_long_query_time }}
log_queries_not_using_indexes={{ mysql_log_queries_not_using_indexes }}

# Binary Logging (moved to data directory for permission compatibility)
log_bin={{ mysql_data_dir }}/mysql-bin
binlog_expire_logs_seconds={{ mysql_binlog_expire_logs_seconds }}

# Security Settings
skip-external-locking

[mysqld_safe]
log-error={{ mysql_log_dir }}/error.log
pid-file=/var/run/mysqld/mysqld.pid

[mysql]
no-auto-rehash

[client]
port={{ mysql_port }}
socket={{ mysql_socket }}
